module Tests exposing (main)

import ChildProcess
import Init
import Node
import Test.Runner.Effectful as Effectful
import Tests.CLI
import Tests.Props


tests : ChildProcess.Permission -> Effectful.Test
tests procPerm =
    Effectful.concat
        [ Effectful.wrap Tests.Props.tests
        , Tests.CLI.tests procPerm
        ]


main : Node.SimpleProgram a
main =
    Node.defineSimpleProgram <| \env ->
        Effectful.initialize env <| \config ->
        Init.await ChildProcess.initialize <| \procPerm ->
            Effectful.run config (tests procPerm)
                |> Node.endSimpleProgram
